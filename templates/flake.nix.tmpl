# Template for the user-packages flake.
#
# Dropped by `glix init` into the root of the user-packages repo. Mutating
# commands (`glix add`, `glix remove`) only edit content between the
# `>>> glix-managed >>>` / `<<< glix-managed <<<` markers. Everything else
# is owned by the user.
{
  description = "glixos user packages";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixos-unstable";

    glixos-core = {
      url = "github:glixos/glixos?dir=core";
      inputs.nixpkgs.follows = "nixpkgs";
    };

    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };

    # >>> glix-managed inputs >>>
    # <<< glix-managed inputs <<<
  };

  outputs = { self, nixpkgs, glixos-core, home-manager, ... }@inputs:
    let
      lib = nixpkgs.lib;

      mkHost = hostName: system:
        let
          manifest = glixos-core.lib.importManifest {
            manifestPath = ./hosts/${hostName}/glix.toml;
            inherit inputs;
          };
        in
        lib.nixosSystem {
          inherit system;
          specialArgs = { inherit inputs manifest; };
          modules = [
            glixos-core.nixosModules.glixos
            home-manager.nixosModules.home-manager
            ./hosts/${hostName}
          ] ++ manifest.systemModules;
        };
    in
    {
      nixosConfigurations = {
        # >>> glix-managed hosts >>>
        # <<< glix-managed hosts <<<
      };
    };
}
