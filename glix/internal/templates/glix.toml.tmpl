# Glixos manifest. Edit via `glix add` / `glix remove` / `glix set`.
# Hand edits are preserved on a best-effort basis.
schema = 1

[settings]
default_scope = "system"
auto_apply    = false
registry_url  = "https://raw.githubusercontent.com/glixos/registry/main/registry.json"

# Packages added by `glix add` appear below.
[packages]
